# ===== AI Agent Mastery — API Keys =====
# Fill in your keys below to run the examples

# Groq (primary — for LangGraph agents)
# Get your key: https://console.groq.com/keys
GROQ_API_KEY=

# OpenAI (optional)
# Get your key: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Google (for ADK agents)
# Get your key: https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# Anthropic (optional)
# Get your key: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ===== Provider Selection =====
# Switch between providers: groq, openai, google, anthropic
LLM_PROVIDER=groq

# ===== Model Configuration =====
# Default models (can be overridden per script)
GROQ_MODEL=llama-3.3-70b-versatile
OPENAI_MODEL=gpt-4o-mini
GOOGLE_MODEL=gemini-2.0-flash
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# ===== Phoenix Observability =====
PHOENIX_PORT=6006

# ===== Cost Budget (Weekly) =====
WEEKLY_BUDGET_USD=5.00
ALERT_THRESHOLD_PCT=80
